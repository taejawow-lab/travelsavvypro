---
// Affiliate-aware link component with click tracking via ascsubtag.
// Usage:
//   <Aff href="https://amazon.com/dp/B07XXXXX" region="us">Nest Thermostat</Aff>
//   <Aff href="https://amazon.com/dp/B07XXXXX" region="us" subtag="custom-id">Buy</Aff>
//
// Auto-appends affiliate tag based on PUBLIC_AMAZON_TAG_{REGION} env var.
// Auto-appends ascsubtag for click attribution (<site>-<page>[-<subtag>]).
// Adds rel="sponsored noopener" for FTC/Google compliance.

export interface Props {
  href: string;
  region?: 'us' | 'uk' | 'kr' | 'jp' | 'ca' | 'de' | 'fr' | 'it' | 'es' | 'in';
  subtag?: string;
  rel?: string;
  class?: string;
  target?: string;
}

const { href, region = 'us', subtag, rel = 'sponsored noopener nofollow', class: cls = '', target = '_blank' } = Astro.props;

const tagEnvMap: Record<string, string> = {
  us: 'PUBLIC_AMAZON_TAG_US',
  uk: 'PUBLIC_AMAZON_TAG_UK',
  kr: 'PUBLIC_AMAZON_TAG_KR',
  jp: 'PUBLIC_AMAZON_TAG_JP',
  ca: 'PUBLIC_AMAZON_TAG_CA',
  de: 'PUBLIC_AMAZON_TAG_DE',
  fr: 'PUBLIC_AMAZON_TAG_FR',
  it: 'PUBLIC_AMAZON_TAG_IT',
  es: 'PUBLIC_AMAZON_TAG_ES',
  in: 'PUBLIC_AMAZON_TAG_IN',
};

// Build page-derived subtag base: <site>-<last-path-segment>
function pageBase(): string {
  try {
    const path = (Astro.url && Astro.url.pathname) ? Astro.url.pathname : '';
    const segment = path.replace(/^\//, '').replace(/\/$/, '').split('/').pop() || 'home';
    let host = '';
    if (Astro.site) {
      const u = new URL(Astro.site.toString());
      host = u.hostname.replace(/^www\./, '').split('.')[0];
    }
    return host ? `${host}-${segment}` : segment;
  } catch {
    return 'site';
  }
}

function sanitizeSubtag(s: string): string {
  // Amazon ascsubtag: alphanumeric, dash, underscore, period. Max 100 chars.
  return s.replace(/[^a-zA-Z0-9._-]/g, '').slice(0, 80);
}

function buildAffUrl(url: string, reg: string): string {
  if (!url.includes('amazon.')) return url;
  try {
    const u = new URL(url);
    const tagEnv = tagEnvMap[reg];
    const tag = tagEnv ? (import.meta.env[tagEnv] as string | undefined) : undefined;
    if (tag) u.searchParams.set('tag', tag);
    const base = pageBase();
    const composed = subtag ? `${base}-${subtag}` : base;
    const final = sanitizeSubtag(composed);
    if (final) u.searchParams.set('ascsubtag', final);
    return u.toString();
  } catch {
    return url;
  }
}

const finalHref = buildAffUrl(href, region);
---

<a href={finalHref} rel={rel} target={target} class={cls}>
  <slot />
</a>
