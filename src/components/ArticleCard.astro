---
export interface Props { title: string; description: string; href: string; image?: string; category?: string; pubDate: Date; readingTime?: number; variant?: 'feature' | 'standard'; index?: number; }
const { title, description, href, image, category, pubDate, readingTime, variant = 'standard', index = 0 } = Astro.props;
const dateline = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }).toUpperCase();
const itemNum = String(index + 1).padStart(2, '0');
const minutes = readingTime || Math.max(8, Math.min(18, Math.round((description?.length || 220) / 24)));
---
<article class={`article-card group relative ${variant === 'standard' ? 'h-full' : ''} ${variant === 'feature' ? 'md:col-span-2' : ''}`}>
  <button type="button" data-bookmark data-title={title} data-url={href} class="save-dot absolute right-4 top-4 z-10 grid h-10 w-10 place-items-center rounded-full border bg-[rgba(251,249,243,.78)] text-[var(--ink-soft)] backdrop-blur transition-colors hover:text-[var(--amber)]" style="border-color: var(--line);" aria-label={`Save ${title}`}>♡</button>
  <a href={href} class={`block ${variant === 'standard' ? 'h-full' : ''} focus-visible:outline-ring`}>
    {image && (<div class={`image-duotone relative mb-4 overflow-hidden border bg-[var(--paper-3)] ${variant === 'feature' ? 'aspect-[16/9]' : 'aspect-[4/3]'}`} style="border-color: var(--line);"><img src={image} alt={title} loading="lazy" decoding="async" class="h-full w-full object-cover transition duration-700 group-hover:scale-[1.035]" /><span class="absolute bottom-3 left-3 bg-[var(--navy-ink)] px-2 py-1 text-[10px] uppercase tracking-[0.16em] text-[var(--on-navy)]" style="font-family: var(--font-mono);">№ {itemNum}</span></div>)}
    <div class="mb-3 flex flex-wrap items-center gap-2 text-[10px] uppercase tracking-[0.16em] text-[var(--ink-faint)]" style="font-family: var(--font-mono);">{category && <span class="border px-2 py-1 text-[var(--amber)]" style="border-color: var(--line);">{category}</span>}<time datetime={pubDate.toISOString()}>{dateline}</time></div>
    <h3 class={`${variant === 'feature' ? 'text-4xl md:text-5xl' : 'text-2xl md:text-[1.7rem]'} mb-3 font-medium leading-[1.02] tracking-[-0.018em] text-balance transition-colors group-hover:text-[var(--navy)]`} style="font-family: var(--font-display);">{title}</h3>
    <p class="mb-8 text-[16px] leading-7 text-[var(--ink-soft)] line-clamp-3">{description}</p>
    <div class="mt-auto flex items-center justify-between gap-4 pt-4 text-[10px] uppercase tracking-[0.16em] text-[var(--ink-faint)]" style="font-family: var(--font-mono); border-top: 1px solid var(--line);"><span>◷ {minutes} min</span><span class="text-[var(--navy)]">Read →</span></div>
  </a>
</article>
