---
export interface Props { title: string; subtitle: string; illustration?: string; ctaText?: string; ctaHref?: string; }
const envIllustration = import.meta.env.PUBLIC_HAS_HERO_ILLUSTRATION === 'true' ? '/images/illustrations/hero.png' : undefined;
const edition = import.meta.env.PUBLIC_SITE_EDITION || 'TS · VOLUME 01';
const tagline = import.meta.env.PUBLIC_SITE_TAGLINE || '';
const { title, subtitle, illustration = envIllustration, ctaText = 'Start with the latest dossier', ctaHref = '#latest' } = Astro.props;
const today = new Date();
const dateline = today.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' }).toUpperCase();
---
<section class="hero-navy relative overflow-hidden text-[var(--on-navy)]">
  <div class="absolute inset-0 opacity-[0.08]" aria-hidden="true" style="background-image: linear-gradient(to right, var(--on-navy-line) 1px, transparent 1px), linear-gradient(to bottom, var(--on-navy-line) 1px, transparent 1px); background-size: 72px 72px;"></div>
  <div class="wrap relative py-14 md:py-20 lg:py-24">
    <div class="mb-10 flex items-center gap-4 text-[10px] uppercase tracking-[0.22em] text-[var(--on-navy-soft)]" style="font-family: var(--font-mono);"><span>{edition}</span><span class="h-px flex-1 bg-[var(--on-navy-line)]"></span><span>{dateline}</span></div>
    <div class="grid items-end gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(340px,.7fr)]"><div><p class="mb-5 text-[11px] uppercase tracking-[0.22em] text-[var(--amber-soft)]" style="font-family: var(--font-mono);">№ 01 · data-grounded travel publication</p><h1 class="max-w-[12ch] text-[clamp(46px,8vw,108px)] font-medium leading-[0.96] tracking-[-0.026em]" style="font-family: var(--font-display);">{title}</h1><p class="mt-7 max-w-2xl text-xl leading-8 text-[var(--on-navy-soft)] md:text-2xl">{subtitle}</p><div class="mt-9 flex flex-wrap items-center gap-4"><a href={ctaHref} class="btn-editorial btn-editorial-light">{ctaText} <span aria-hidden="true">→</span></a><a href="/search/" class="btn-editorial btn-editorial-ghost">Search the archive</a>{tagline && <span class="text-[10px] uppercase tracking-[0.18em] text-[var(--on-navy-soft)]" style="font-family: var(--font-mono);">· {tagline}</span>}</div></div>
      <div class="relative"><div class="mb-3 text-[10px] uppercase tracking-[0.18em] text-[var(--on-navy-soft)]" style="font-family: var(--font-mono);">Cover · verified routes</div>{illustration ? (<figure class="hero-frame relative m-0"><img src={illustration} alt="" class="aspect-[4/3] w-full object-cover" loading="eager" fetchpriority="high" decoding="async" /><figcaption class="absolute bottom-4 left-4 border bg-[rgba(8,19,29,.72)] px-3 py-2 text-[10px] uppercase tracking-[0.18em] text-[var(--on-navy)] backdrop-blur" style="border-color: var(--on-navy-line); font-family: var(--font-mono);">Current dossier</figcaption></figure>) : (<div class="hero-frame aspect-[4/3] border" style="border-color: var(--on-navy-line);"></div>)}</div></div>
    <div class="mt-12 grid gap-3 border-t pt-5 text-[10px] uppercase tracking-[0.18em] text-[var(--on-navy-soft)] sm:grid-cols-4" style="border-color: var(--on-navy-line); font-family: var(--font-mono);"><span><b class="text-[var(--on-navy)]">39</b> preserved travel guides</span><span><b class="text-[var(--on-navy)]">8+</b> sources per new guide</span><span><b class="text-[var(--on-navy)]">No</b> sponsored stays</span><span><b class="text-[var(--on-navy)]">SEO</b> routes retained</span></div>
  </div>
</section>
