---
export interface Props {
  title: string;
  subtitle: string;
  illustration?: string;
  ctaText?: string;
  ctaHref?: string;
}

const {
  title,
  subtitle,
  illustration,
  ctaText = 'Browse Articles',
  ctaHref = '#latest',
} = Astro.props;
---

<section class="relative overflow-hidden bg-gradient-to-b from-background to-muted/30">
  <!-- 추상 SVG 배경 패턴 (사이트 컬러 자동 반영) -->
  <div class="absolute inset-0 pointer-events-none opacity-50" aria-hidden="true">
    <svg class="absolute top-0 right-0 w-2/3 h-full" viewBox="0 0 800 600" fill="none" preserveAspectRatio="xMaxYMid slice">
      <defs>
        <radialGradient id="hero-glow-1" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgb(var(--color-primary))" stop-opacity="0.4"/>
          <stop offset="100%" stop-color="rgb(var(--color-primary))" stop-opacity="0"/>
        </radialGradient>
        <radialGradient id="hero-glow-2" cx="50%" cy="50%" r="50%">
          <stop offset="0%" stop-color="rgb(var(--color-accent))" stop-opacity="0.3"/>
          <stop offset="100%" stop-color="rgb(var(--color-accent))" stop-opacity="0"/>
        </radialGradient>
      </defs>
      <circle cx="600" cy="200" r="300" fill="url(#hero-glow-1)"/>
      <circle cx="400" cy="450" r="200" fill="url(#hero-glow-2)"/>
    </svg>
  </div>

  <div class="container mx-auto px-4 py-16 md:py-24 relative">
    <div class="grid grid-cols-1 md:grid-cols-[1.2fr_1fr] gap-12 items-center">
      <div class="text-center md:text-left">
        <h1
          class="text-4xl md:text-6xl font-bold mb-6 text-balance"
          style="font-family: var(--font-heading)"
        >
          {title}
        </h1>
        <p class="text-xl text-muted-foreground text-pretty mb-8 max-w-2xl">
          {subtitle}
        </p>
        <a href={ctaHref} class="btn-primary">
          {ctaText}
          <svg class="ml-2 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
      </div>
      <div class="flex justify-center items-center">
        {illustration ? (
          <img src={illustration} alt="" class="max-w-md w-full h-auto" loading="eager" />
        ) : (
          <!-- 추상 SVG 비주얼 — 일러스트 없을 때 placeholder. 사이트 컬러 자동 반영 -->
          <svg class="w-full max-w-md h-auto" viewBox="0 0 400 400" fill="none" aria-hidden="true">
            <defs>
              <linearGradient id="card-grad-1" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="rgb(var(--color-primary))"/>
                <stop offset="100%" stop-color="rgb(var(--color-accent))"/>
              </linearGradient>
              <linearGradient id="card-grad-2" x1="0%" y1="0%" x2="100%" y2="100%">
                <stop offset="0%" stop-color="rgb(var(--color-accent))" stop-opacity="0.7"/>
                <stop offset="100%" stop-color="rgb(var(--color-primary))" stop-opacity="0.4"/>
              </linearGradient>
            </defs>

            <!-- 큰 부드러운 모양 (일러스트 대체) -->
            <rect x="50" y="80" width="200" height="240" rx="32" fill="url(#card-grad-1)" opacity="0.9"/>
            <rect x="150" y="120" width="200" height="240" rx="32" fill="url(#card-grad-2)" opacity="0.8" transform="rotate(-6 250 240)"/>

            <!-- 추상 데이터 점·선 (데이터 기반 매체 메타포) -->
            <circle cx="100" cy="140" r="6" fill="rgb(var(--color-foreground))" opacity="0.5"/>
            <circle cx="160" cy="180" r="4" fill="rgb(var(--color-foreground))" opacity="0.5"/>
            <circle cx="220" cy="160" r="5" fill="rgb(var(--color-foreground))" opacity="0.5"/>
            <line x1="100" y1="140" x2="160" y2="180" stroke="rgb(var(--color-foreground))" stroke-width="1.5" opacity="0.3"/>
            <line x1="160" y1="180" x2="220" y2="160" stroke="rgb(var(--color-foreground))" stroke-width="1.5" opacity="0.3"/>

            <!-- 작은 액센트 도형 -->
            <circle cx="320" cy="100" r="20" fill="rgb(var(--color-accent))" opacity="0.6"/>
            <circle cx="80" cy="320" r="14" fill="rgb(var(--color-primary))" opacity="0.7"/>
          </svg>
        )}
      </div>
    </div>
  </div>
</section>
