---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import ArticleCard from '../components/ArticleCard.astro';
const posts = (await getCollection('posts')).filter((post) => !post.data.draft).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = posts.slice(0, 3);
const recentPosts = posts.slice(3, 12);
const siteName = import.meta.env.PUBLIC_SITE_NAME || 'TravelSavvyPro';
const siteDescription = import.meta.env.PUBLIC_SITE_DESCRIPTION || '';
const heroTitle = import.meta.env.PUBLIC_SITE_HERO_TITLE || siteName;
const heroSubtitle = import.meta.env.PUBLIC_SITE_HERO_SUBTITLE || siteDescription;
---
<BaseLayout title="Travel Planning, Flight and Hotel Guides" description={siteDescription}>
  <Hero title={heroTitle} subtitle={heroSubtitle} illustration={featuredPosts[0]?.data.heroImage} />
  <section class="border-y" style="border-color: var(--line); background: var(--paper-2);"><div class="wrap grid gap-6 py-8 md:grid-cols-4">{['Cited primary travel data', 'No sponsored stays', 'Actionable checklists', 'Updated route evidence'].map((item, i) => (<div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.16em] text-[var(--ink-soft)]" style="font-family: var(--font-mono);"><span class="text-[var(--amber)]">§ 0{i + 1}</span><span>{item}</span></div>))}</div></section>
  {featuredPosts.length > 0 && (<section class="wrap py-20 md:py-28"><div class="mb-12 grid gap-6 md:grid-cols-[minmax(0,.7fr)_minmax(0,1fr)_auto] md:items-start"><p class="text-[10px] uppercase tracking-[0.22em] text-[var(--amber)]" style="font-family: var(--font-mono);">¶ Section 01</p><div><h2 class="m-0 text-5xl font-medium leading-none tracking-[-0.02em] md:text-7xl" style="font-family: var(--font-display);">Featured</h2><p class="mt-7 max-w-xl text-xl leading-8 text-[var(--ink-soft)]">Hand-picked stories grounded in primary sources — what we believe is worth your attention right now.</p></div><a href="/posts/" class="btn-editorial btn-editorial-outline self-start">View archive →</a></div><div class="grid gap-8 md:grid-cols-2">{featuredPosts.map((post, i) => (<ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}/`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} variant={i === 0 ? 'feature' : 'standard'} index={i} />))}</div></section>)}
  <section class="border-y" style="border-color: var(--line);"><div class="wrap grid gap-8 py-14 md:grid-cols-[.8fr_1.2fr]"><div><p class="text-[10px] uppercase tracking-[0.22em] text-[var(--amber)]" style="font-family: var(--font-mono);">How we know</p><h2 class="mt-4 text-4xl font-medium md:text-5xl" style="font-family: var(--font-display);">Travel advice with evidence attached.</h2></div><div class="grid gap-4 sm:grid-cols-3">{['Airline and airport data', 'Official border guidance', 'Accommodation and insurance terms'].map((x) => <div class="border bg-[var(--card)] p-5 text-[15px] leading-7 text-[var(--ink-soft)]" style="border-color: var(--line);"><span class="mb-3 block text-[var(--verify)]">Verified</span>{x}</div>)}</div></div></section>
  {recentPosts.length > 0 && (<section id="latest" class="wrap py-20 md:py-28"><div class="mb-12 flex flex-col justify-between gap-5 md:flex-row md:items-end"><div><p class="text-[10px] uppercase tracking-[0.22em] text-[var(--amber)]" style="font-family: var(--font-mono);">¶ Section 02</p><h2 class="mt-3 text-5xl font-medium leading-none tracking-[-0.02em] md:text-6xl" style="font-family: var(--font-display);">Recent</h2></div><p class="text-[10px] uppercase tracking-[0.18em] text-[var(--ink-faint)]" style="font-family: var(--font-mono);">↓ {recentPosts.length} stories · sorted by date</p></div><div class="grid grid-cols-1 gap-x-8 gap-y-14 md:grid-cols-2 lg:grid-cols-3">{recentPosts.map((post, i) => (<ArticleCard title={post.data.title} description={post.data.description} href={`/posts/${post.slug}/`} image={post.data.heroImage} category={post.data.category} pubDate={post.data.pubDate} index={i + 3} />))}</div></section>)}
</BaseLayout>
