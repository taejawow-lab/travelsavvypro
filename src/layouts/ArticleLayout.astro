---
import BaseLayout from './BaseLayout.astro';
import TOC from '../components/TOC.astro';
import References from '../components/References.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
  category?: string;
  sources?: Array<{ title: string; url: string; author?: string; year?: string }>;
  affiliate?: boolean;
  visualsCount?: number;
  hasVideo?: boolean;
  headings?: Array<{ depth: number; slug: string; text: string }>;
  faq?: Array<{ question: string; answer: string }>;
  internalLinks?: string[];
}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  tags = [],
  category,
  sources = [],
  affiliate = false,
  visualsCount = 0,
  hasVideo = false,
  headings = [],
  faq = [],
  internalLinks = [],
} = Astro.props;

const articleSchema = {
  '@type': 'Article',
  headline: title,
  description,
  image: heroImage,
  datePublished: pubDate?.toISOString(),
  dateModified: (updatedDate || pubDate)?.toISOString(),
  author: {
    '@type': 'Organization',
    name: import.meta.env.PUBLIC_SITE_NAME + ' Editorial Team',
    url: import.meta.env.PUBLIC_SITE_URL,
  },
  publisher: {
    '@type': 'NewsMediaOrganization',
    name: import.meta.env.PUBLIC_SITE_NAME,
    url: import.meta.env.PUBLIC_SITE_URL,
  },
};

const faqSchema = faq.length > 0 ? {
  '@type': 'FAQPage',
  mainEntity: faq.map((q) => ({
    '@type': 'Question',
    name: q.question,
    acceptedAnswer: { '@type': 'Answer', text: q.answer },
  })),
} : null;

const siteUrlBC = (Astro.site ? Astro.site.toString().replace(/\/$/, '') : (import.meta.env.PUBLIC_SITE_URL || 'https://travelsavvypro.org'));
const siteNameBC = import.meta.env.PUBLIC_SITE_NAME || 'Editorial';
const postUrlBC = `${siteUrlBC}${Astro.url.pathname}`;
const categorySlug = category ? category.toLowerCase().trim().replace(/\s+/g, '-') : '';
const breadcrumbSchema = {
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: siteNameBC, item: `${siteUrlBC}/` },
    ...(category ? [{ '@type': 'ListItem', position: 2, name: category, item: `${siteUrlBC}/category/${categorySlug}/` }] : []),
    { '@type': 'ListItem', position: (category ? 3 : 2), name: title, item: postUrlBC },
  ],
};

const schema = faqSchema ? {
  '@context': 'https://schema.org',
  '@graph': [articleSchema, breadcrumbSchema, faqSchema],
} : { '@context': 'https://schema.org', '@graph': [articleSchema, breadcrumbSchema] };

const lang = import.meta.env.PUBLIC_SITE_LANG || 'en';
const localeMap: Record<string, string> = { ko: 'ko-KR', ja: 'ja-JP', en: 'en-US' };
const tMap: Record<string, { published: string; updated: string; sources: string; visuals: string; video: string; related: string; explore: string }> = {
  ko: { published: '발행일', updated: '갱신', sources: '건 1차 자료', visuals: '종 시각 자료', video: '영상 요약', related: '함께 읽으면 좋은 글', explore: '관련 경로 열기' },
  ja: { published: '公開', updated: '更新', sources: '件の出典', visuals: '点のビジュアル', video: '動画要約', related: 'あわせて読みたい', explore: '関連ページを開く' },
  en: { published: 'Published', updated: 'Updated', sources: 'sources cited', visuals: 'visuals', video: 'Video summary', related: 'Related Reading', explore: 'Open related path' },
};
const t = tMap[lang] || tMap.en;
const locale = localeMap[lang] || 'en-US';
---

<BaseLayout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  publishedTime={pubDate?.toISOString()}
  modifiedTime={(updatedDate || pubDate)?.toISOString()}
  schema={schema}
>
  <div class="fixed left-0 top-0 z-[60] h-1 w-full bg-transparent" aria-hidden="true"><div id="reading-progress" class="h-full w-0 bg-[var(--amber)]"></div></div>
  <article class="wrap py-10 md:py-16">
    <header class="mx-auto mb-8 max-w-4xl text-center">
      <div class="mb-6 flex flex-wrap items-center justify-center gap-2 text-[10px] uppercase tracking-[0.18em]" style="font-family: var(--font-mono);">
        {category && (<a href={`/category/${categorySlug}/`} class="border px-3 py-2 text-[var(--amber)]" style="border-color: var(--line);">{category}</a>)}
        <span class="border px-3 py-2 text-[var(--verify)]" style="border-color: var(--line);">Verified</span>
        <span class="border px-3 py-2 text-[var(--ink-faint)]" style="border-color: var(--line);">{sources.length} {t.sources}</span>
      </div>
      <h1 class="mb-6 text-balance text-5xl font-medium leading-[0.98] tracking-[-0.026em] md:text-7xl" style="font-family: var(--font-display);">{title}</h1>
      <p class="mx-auto max-w-3xl text-xl leading-8 text-[var(--ink-soft)] md:text-2xl">{description}</p>
      <div class="mt-7 flex flex-wrap items-center justify-center gap-3 text-[11px] uppercase tracking-[0.14em] text-[var(--ink-faint)]" style="font-family: var(--font-mono);">
        <time datetime={pubDate?.toISOString()} class="border px-3 py-2" style="border-color: var(--line);">{t.published} {pubDate?.toLocaleDateString(locale)}</time>
        {updatedDate && updatedDate.getTime() !== pubDate.getTime() && (<time datetime={updatedDate.toISOString()} class="border px-3 py-2 text-[var(--navy)]" style="border-color: var(--line);">{t.updated} {updatedDate.toLocaleDateString(locale)}</time>)}
        {visualsCount > 0 && <span class="border px-3 py-2" style="border-color: var(--line);">{visualsCount} {t.visuals}</span>}
        {hasVideo && <span class="border px-3 py-2 text-[var(--amber)]" style="border-color: var(--line);">Video summary</span>}
        <button type="button" data-bookmark data-title={title} data-url={Astro.url.pathname} class="border px-3 py-2 text-[var(--ink-soft)] hover:text-[var(--amber)]" style="border-color: var(--line);">♡</button>
        <button type="button" data-copy-link class="border px-3 py-2 text-[var(--ink-soft)] hover:text-[var(--amber)]" style="border-color: var(--line);">Copy link</button>
      </div>
    </header>
    {heroImage && (<figure class="mx-auto mb-10 max-w-5xl"><img src={heroImage} alt={title} width="1280" height="720" loading="eager" fetchpriority="high" decoding="async" class="aspect-[16/9] w-full object-cover shadow-xl" style="border: 1px solid var(--line);"/><figcaption class="mt-3 text-[10px] uppercase tracking-[0.16em] text-[var(--ink-faint)]" style="font-family: var(--font-mono);">Cover · source-backed travel dossier</figcaption></figure>)}
    <script is:inline>
      (() => {
        const bar = document.getElementById('reading-progress');
        const set = () => {
          const max = document.documentElement.scrollHeight - innerHeight;
          if (bar && max > 0) bar.style.width = Math.min(100, Math.max(0, scrollY / max * 100)) + '%';
        };
        addEventListener('scroll', set, { passive: true }); set();
        document.addEventListener('click', (e) => { if (e.target.closest('[data-copy-link]')) navigator.clipboard?.writeText(location.href); });
      })();
    </script>

    {affiliate && <AffiliateDisclosure />}

    <div class="grid grid-cols-1 lg:grid-cols-[minmax(0,1fr)_280px] gap-10 lg:gap-12">
      <div class="prose-article min-w-0">
        <slot />
        {sources.length > 0 && <References sources={sources} />}
      </div>

      {headings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-28">
            <TOC headings={headings} />
          </div>
        </aside>
      )}
    </div>

    {internalLinks.length > 0 && (
      <section class="mt-14 rounded-[1.5rem] border border-border/70 bg-card/80 p-5 shadow-sm sm:p-7">
        <div class="mb-5 flex items-end justify-between gap-4 border-b border-border/70 pb-4">
          <h2 class="m-0 text-2xl font-bold" style="font-family: var(--font-display);">{t.related}</h2>
          <span class="hidden sm:inline text-xs uppercase tracking-[0.16em] text-muted-foreground">{t.explore}</span>
        </div>
        <ul class="grid gap-3 sm:grid-cols-2">
          {internalLinks.map((link) => (
            <li>
              <a href={link} class="group flex min-h-12 items-center justify-between gap-3 rounded-2xl border border-border/70 bg-background px-4 py-3 text-sm font-semibold text-foreground/80 no-underline shadow-sm transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary hover:shadow-md focus-visible:outline-ring">
                <span class="truncate font-mono text-xs sm:text-sm">{link}</span>
                <span class="shrink-0 text-primary transition-transform group-hover:translate-x-1" aria-hidden="true">→</span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {tags.length > 0 && (
      <footer class="mt-12 pt-8 border-t border-border">
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag.toLowerCase().trim().replace(/[\/\\&%?#=]/g, '-').replace(/\s+/g, '-').replace(/-+/g, '-').replace(/^-|-$/g, '')}`}
              class="inline-flex min-h-9 items-center rounded-full bg-muted px-3 py-1 text-sm text-muted-foreground hover:bg-primary hover:text-primary-foreground transition-colors"
            >
              #{tag}
            </a>
          ))}
        </div>
      </footer>
    )}
  </article>
</BaseLayout>
